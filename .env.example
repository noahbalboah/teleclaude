# Bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=7123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Target chat ID — use @userinfobot or @RawDataBot to find yours
# Positive for private chats, negative for groups (e.g., -100123456789)
TELEGRAM_CHAT_ID=-100123456789

# Comma-separated Telegram user IDs allowed to interact
# Use @userinfobot to find your user ID
ALLOWED_USER_IDS=123456789

# Auto-approve all permission requests (required for headless mode)
AUTO_APPROVE=true

# Or selectively auto-approve specific tools
# AUTO_APPROVE_TOOLS=Bash,Write,Edit

# Session name (default: claude)
SERVER_NAME=claude

# Auto-discover project folders as sessions
# PROJECTS_DIR=/home/youruser/projects

# Working directory for Claude (default: $HOME)
CLAUDE_CWD=/home/youruser

# Max milliseconds per claude -p call (default: 300000 = 5 min)
# CLAUDE_TIMEOUT=300000

# Remote relays: name@host:port (comma-separated)
# REMOTE_SESSIONS=vm2@10.0.0.5:4100,staging@10.0.0.6:4200

# Relay TCP port (default: 4100)
# RELAY_PORT=4100

# Hub idle shutdown timeout (default: 0 = never)
HUB_IDLE_TIMEOUT=0
