{
  "name": "teleclaude",
  "version": "0.1.0",
  "description": "Telegram bridge for Claude Code — control headless sessions from your phone",
  "type": "module",
  "bin": {
    "claude-telegram-hub": "src/hub/hub.ts",
    "claude-telegram-relay": "src/relay/relay.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev:hub": "bun run src/hub/hub.ts",
    "dev:relay": "bun run src/relay/relay.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write ."
  },
  "files": [
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "telegram",
    "automation"
  ],
  "dependencies": {
    "grammy": "^1.35.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "1.3.11",
    "typescript": "6.0.2"
  }
}
